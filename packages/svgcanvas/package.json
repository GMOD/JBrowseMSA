{
  "name": "@jbrowse/svgcanvas",
  "version": "5.0.9",
  "description": "Draw on SVG using Canvas's 2D Context API - ESM fork of svgcanvas",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "types": "dist/index.d.ts",
    "main": "dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GMOD/react-msaview.git",
    "directory": "packages/svgcanvas"
  }
}
