---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  wide?: boolean
}
const { title, description, wide } = Astro.props
const base = import.meta.env.BASE_URL
const nav = [
  { href: base, label: 'Home' },
  { href: `${base}/guide`, label: 'User guide' },
  { href: `${base}/embedding`, label: 'Embedding' },
  { href: `${base}/examples`, label: 'Examples' },
  { href: `${base}/r-package`, label: 'R package' },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>JBrowseMSA</a>
      <nav>
        {nav.map(item => <a href={item.href}>{item.label}</a>)}
      </nav>
      <a
        class="github-icon"
        href="https://github.com/GMOD/JBrowseMSA"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      ></a>
    </header>
    <main class:list={{ wide }}>
      <slot />
    </main>
    <footer class="site-footer">
      <span>
        react-msaview (JBrowseMSA) ·
        <a href="https://github.com/GMOD/JBrowseMSA">GitHub</a> ·
        part of <a href="https://jbrowse.org">JBrowse</a>
      </span>
    </footer>
  </body>
</html>
