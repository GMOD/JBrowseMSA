---
// A figure whose image links to a live JBrowse session. `src` is a filename
// under public/media; `href` is the full JBrowse session URL.
import Figure from './Figure.astro'

interface Props {
  src: string
  alt: string
  title?: string
  body: string
  href: string
}
const { src, alt, title, body, href } = Astro.props
---

<Figure src={src} alt={alt} href={href}>
  {
    title ? (
      <>
        <strong>{title}</strong> —
      </>
    ) : null
  }{body}
  <a href={href} target="_blank" rel="noopener">Open in JBrowse ↗</a>
</Figure>
