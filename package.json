{
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter app dev",
    "watch": "pnpm -r --parallel --filter svgcanvas --filter msa-parsers --filter react-msaview --filter app run '/^(watch|dev)$/'",
    "build": "pnpm --filter svgcanvas build && pnpm --filter msa-parsers build && pnpm --filter react-msaview build",
    "build:lib": "pnpm --filter svgcanvas build && pnpm --filter msa-parsers build && pnpm --filter react-msaview build:esm",
    "build:site": "pnpm --filter website build",
    "build:pages": "pnpm build:lib && pnpm build:site && pnpm --filter app build && node scripts/assemble-pages.mjs",
    "deploy:pages": "pnpm build:pages && gh-pages -d pages-dist -t",
    "clean": "pnpm -r run clean",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest",
    "figures": "vitest run --config vitest.figures.config.ts",
    "screenshots": "pnpm --filter app exec vite build && node scripts/screenshots/generate.mjs",
    "typecheck": "pnpm -r --filter=!website exec tsc --noEmit && pnpm --filter website exec astro sync && pnpm --filter website exec tsc --noEmit",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "attw": "pnpm -r --filter react-msaview --filter msa-parsers --filter @jbrowse/svgcanvas exec attw --pack . --ignore-rules cjs-resolves-to-esm"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@emotion/react": "^11.14.0",
    "@eslint/js": "^10.0.1",
    "@jbrowse/core": "^4.3.0",
    "@jbrowse/mobx-state-tree": "^5.11.0",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/system": "^7.3.11",
    "@types/d3": "^7.4.3",
    "@types/d3-array": "^3.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/normalize-wheel": "^1.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.4.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "flatbush": "^4.6.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "mobx": "^6.16.1",
    "mobx-react": "^9.2.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "puppeteer-core": "^25.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "serve-handler": "^6.1.7",
    "slugify": "^1.6.9",
    "tss-react": "^4.9.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
