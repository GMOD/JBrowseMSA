---
import Base from '../layouts/Base.astro'

const base = import.meta.env.BASE_URL

// Live, declarative links — the whole multi-view JBrowse session is in the URL,
// no saved session to set up. Both links drive JBrowse 2 via a session spec
// (?session=spec-…) against the published jbrowse-plugin-msaview.
//
// `combined` opens an F12 (DNA) Linear Genome View — gene track + Multiz mammal
// alignment, reference colored by codon frame (colorByCDS) so the cetacean
// frameshift reads out — beside an MsaView, as two independent views.
//
// `proteinLinked` opens the human SRC gene beside the Src-family kinase MsaView
// *connected* to it: the MsaView's connectedViewId references the LGV's pinned
// id and a connectedFeature carries the transcript model, so the two views share
// coordinates (click a residue → genome navigates to its codon; hover the gene →
// the MSA column highlights). Built by scripts/src-protein-link/generate.mjs.
//
// `brafV600` is the same connected pattern on BRAF, opened on the V600E codon:
// the LGV is positioned on the V600 codon (with a genome highlight band), colors
// the reference by codon frame (colorByCDS), collapses the gene track to the
// longest coding transcript, and carries a ClinVar pathogenic-variant track; the
// MsaView carries highlightColumns so the invariant V600 alignment column is lit
// up across the RAF family. Built by scripts/braf-protein-link/generate.mjs
// (ClinVar data: build-clinvar.mjs).
//
// `tp53R248` is the connected pattern on TP53, opened on the R248 codon, with a
// ClinVar pathogenic-variant track in the LGV — so the wall of disease variants
// over the R248 codon sits directly above the 100%-conserved alignment column.
// Built by scripts/tp53-protein-link/generate.mjs (data: build-data.mjs).
const links = {
  combined:
    'https://jbrowse.org/code/jb2/webgl-poc/?config=https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Fjbrowse-msa-combined-config.json&session=spec-%7B%22views%22%3A%5B%7B%22type%22%3A%22LinearGenomeView%22%2C%22assembly%22%3A%22hg38%22%2C%22loc%22%3A%22chr5%3A177%2C405%2C935-177%2C406%2C012%22%2C%22highlight%22%3A%5B%22chr5%3A177%2C405%2C970-177%2C405%2C973%22%5D%2C%22colorByCDS%22%3Atrue%2C%22tracks%22%3A%5B%22hg38-ncbiRefSeq%22%2C%7B%22trackId%22%3A%22hg38-multiz470way%22%2C%22displaySnapshot%22%3A%7B%22type%22%3A%22LinearMafDisplay%22%2C%22rowHeight%22%3A22%7D%7D%5D%7D%2C%7B%22type%22%3A%22MsaView%22%2C%22msaFileLocation%22%3A%7B%22uri%22%3A%22https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Ff12-cetacean-region.stock%22%7D%2C%22colorSchemeName%22%3A%22percent_identity_dynamic%22%2C%22treeAreaWidth%22%3A200%2C%22colWidth%22%3A15%2C%22rowHeight%22%3A16%2C%22labelsAlignRight%22%3Atrue%7D%5D%7D',
  proteinLinked:
    'https://jbrowse.org/code/jb2/webgl-poc/?config=https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Fjbrowse-msa-combined-config.json&session=spec-%7B%22views%22%3A%5B%7B%22type%22%3A%22LinearGenomeView%22%2C%22id%22%3A%22lgv-src%22%2C%22assembly%22%3A%22hg38%22%2C%22loc%22%3A%22chr20%3A37%2C344%2C685-37%2C406%2C050%22%2C%22colorByCDS%22%3Atrue%2C%22tracks%22%3A%5B%7B%22trackId%22%3A%22hg38-ncbiRefSeq%22%2C%22displaySnapshot%22%3A%7B%22type%22%3A%22LinearBasicDisplay%22%2C%22geneGlyphMode%22%3A%22longestCoding%22%7D%7D%5D%7D%2C%7B%22type%22%3A%22MsaView%22%2C%22connectedViewId%22%3A%22lgv-src%22%2C%22connectedFeature%22%3A%7B%22type%22%3A%22mRNA%22%2C%22refName%22%3A%22chr20%22%2C%22start%22%3A37384153%2C%22end%22%3A37403376%2C%22strand%22%3A1%2C%22name%22%3A%22NM_005417.5%22%2C%22subfeatures%22%3A%5B%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37384153%2C%22end%22%3A37384403%2C%22strand%22%3A1%2C%22phase%22%3A0%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37386074%2C%22end%22%3A37386174%2C%22strand%22%3A1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37393894%2C%22end%22%3A37393993%2C%22strand%22%3A1%2C%22phase%22%3A1%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37394173%2C%22end%22%3A37394277%2C%22strand%22%3A1%2C%22phase%22%3A1%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37396161%2C%22end%22%3A37396311%2C%22strand%22%3A1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37397698%2C%22end%22%3A37397854%2C%22strand%22%3A1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37400114%2C%22end%22%3A37400294%2C%22strand%22%3A1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37401601%2C%22end%22%3A37401678%2C%22strand%22%3A1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37402434%2C%22end%22%3A37402588%2C%22strand%22%3A1%2C%22phase%22%3A0%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A37402748%2C%22end%22%3A37402880%2C%22strand%22%3A1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22