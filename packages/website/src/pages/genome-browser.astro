  tp53R248:
    'https://jbrowse.org/code/jb2/webgl-poc/?config=https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Fjbrowse-msa-combined-config.json&session=spec-%7B%22views%22%3A%5B%7B%22type%22%3A%22LinearGenomeView%22%2C%22id%22%3A%22lgv-tp53%22%2C%22assembly%22%3A%22hg38%22%2C%22loc%22%3A%22chr17%3A7%2C674%2C189-7%2C674%2C251%22%2C%22highlight%22%3A%5B%22chr17%3A7%2C674%2C219-7%2C674%2C221%22%5D%2C%22colorByCDS%22%3Atrue%2C%22tracks%22%3A%5B%7B%22trackId%22%3A%22hg38-ncbiRefSeq%22%2C%22displaySnapshot%22%3A%7B%22type%22%3A%22LinearBasicDisplay%22%2C%22geneGlyphMode%22%3A%22longestCoding%22%7D%7D%2C%22hg38-tp53-clinvar-pathogenic%22%5D%7D%2C%7B%22type%22%3A%22MsaView%22%2C%22connectedViewId%22%3A%22lgv-tp53%22%2C%22connectedFeature%22%3A%7B%22type%22%3A%22mRNA%22%2C%22refName%22%3A%22chr17%22%2C%22start%22%3A7669611%2C%22end%22%3A7676594%2C%22strand%22%3A-1%2C%22name%22%3A%22NM_000546.6%22%2C%22subfeatures%22%3A%5B%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7669611%2C%22end%22%3A7669690%2C%22strand%22%3A-1%2C%22phase%22%3A1%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7670608%2C%22end%22%3A7670715%2C%22strand%22%3A-1%2C%22phase%22%3A0%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7673534%2C%22end%22%3A7673608%2C%22strand%22%3A-1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7673700%2C%22end%22%3A7673837%2C%22strand%22%3A-1%2C%22phase%22%3A1%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7674180%2C%22end%22%3A7674290%2C%22strand%22%3A-1%2C%22phase%22%3A0%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7674858%2C%22end%22%3A7674971%2C%22strand%22%3A-1%2C%22phase%22%3A2%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7675052%2C%22end%22%3A7675236%2C%22strand%22%3A-1%2C%22phase%22%3A0%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7675993%2C%22end%22%3A7676272%2C%22strand%22%3A-1%2C%22phase%22%3A0%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7676381%2C%22end%22%3A7676403%2C%22strand%22%3A-1%2C%22phase%22%3A1%7D%2C%7B%22type%22%3A%22CDS%22%2C%22start%22%3A7676