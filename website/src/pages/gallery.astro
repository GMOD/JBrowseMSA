// biological story that reads straight off the alignment + tree.
const figures = [
  {
    src: 'f12-exon-architecture.png',
    title: 'Gene structure overlay (DNA)',
    body: 'Coagulation factor XII coding alignment with its 14 exons overlaid — each exon the same color across species, drawn through the same overlay path as InterProScan domains (built by react-msaview-cli genestructure). The whole gene’s exon architecture reads straight down the alignment.',
  },
  {
    src: 'f12-frameshift.png',
    title: 'Pseudogenization',
    body: 'F12 is intact in land mammals and the manatee (a fully aquatic sirenian), but a single-base deletion shared by exactly the four cetaceans — beside premature stop codons elsewhere — disables it. Gene loss visible at the nucleotide level, in exon 3, which a protein alignment cannot show.',
  },
  {
    src: 'within-protein-conservation.png',
    title: 'Within-protein conservation',
    body: 'p53 across vertebrates, relative to human: the central DNA-binding domain collapses to dots while the variable N- and C-termini stay full of substitutions.',
  },
  {
    src: 'extreme-conservation.png',
    title: 'Extreme conservation',
    body: 'Histone H4, one of the most conserved proteins known, is almost entirely dots relative to human — only the most distant lineages differ.',
  },
  {
    src: 'convergent-evolution.png',
    title: 'Convergent evolution',
    body: 'Prestin: echolocating bats and toothed whales group together, pulled off the species tree by convergent selection for high-frequency hearing.',
  },
  {
    src: 'gene-duplication.png',
    title: 'Gene duplication',
    body: 'The globin family groups by globin type across species rather than by species — the signature of ancient gene duplication.',
  },
  {
    src: 'deep-phylogeny.png',
    title: 'Deep phylogeny',
    body: 'Cytochrome c from mammals to plants and fungi: a single tree spanning more than a billion years of divergence.',
  },
  {
    src: 'tree-of-life.png',
    title: 'Tree of life',
    body: 'Elongation factor EF-1α/EF-Tu across bacteria, archaea, and eukaryotes — the three domains of life read off the tree.',
  },
  {
    src: 'host-range.png',
    title: 'Host range',
    body: 'ACE2 relative to human: the few divergent spike-contact residues in the N-terminal peptidase domain stand out of an otherwise conserved protein.',
  },
  {
    src: 'processing-conservation.png',
    title: 'Post-translational processing',
    body: 'Insulin relative to human: the conserved B and A chains versus the variable, cleaved-out C-peptide.',
  },
  {
    src: 'reference-dots.png',
    title: 'Reference comparison',
    body: 'MyD88 relative to human: lineage-specific substitutions (and the bat clade) stand out against the inferred tree.',
  },
  {
    src: 'real-domains.png',
    title: 'Domain architecture',
    body: 'The kinase family with InterProScan domains: shared SH3 + SH2 + kinase architecture aligns down every member.',
  },
  {
    src: 'opsin-classes.png',
    title: 'Opsin classes',
    body: 'Vertebrate opsins sorted by class, with the InterProScan 7TM-GPCR domain overlaid across each sequence.',
  },
  {
    src: 'large-tree.png',
    title: 'Scale',
    body: 'A large lysine-biosynthesis alignment and tree, rendered through the tiled canvas system.',
  },
