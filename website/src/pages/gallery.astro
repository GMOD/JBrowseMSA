import Base from '../layouts/Base.astro'
import Figure from '../components/Figure.astro'
import JBrowseFigure from '../components/JBrowseFigure.astro'
import { f12CombinedCloseupUrl } from '../lib/f12CombinedLinks'

const base = import.meta.env.BASE_URL

// Standalone react-msaview figures — just an alignment, a tree, and optional
// feature overlays, no genome browser. Generated by scripts/screenshots
// (specs.mjs). Each tells one biological story that reads straight off the
// picture.
// One figure per distinct viewer capability rather than per interesting
// organism — the standalone demo app at /examples carries the full set of
// biological stories. Each entry here shows something the others don't:
// feature overlays, domain annotation, reference diffing, tree topology, RNA
// secondary structure, gene arrows, base-resolution DNA, scale.
const figures = [
  {
    src: 'real-domains.png',
    title: 'Domain architecture',
    body: 'The Src-family kinases with InterProScan annotations: the shared SH3 + SH2 + kinase domain blocks line up down every member, so the family’s domain layout reads straight across the alignment.',
  },
  {
    src: 'within-protein-conservation.png',
    title: 'A dominant functional domain',
    body: 'p53’s InterProScan domains overlaid: the central DNA-binding domain (red) — where most cancer mutations cluster — forms the bulk of the protein, flanked by the short N-terminal transactivation motifs. The overlay maps the functional architecture onto the alignment.',
  },
  {
    src: 'extreme-conservation.png',
    title: 'Reference comparison (dots)',
    body: 'Diffing against a reference (relativeTo) collapses identical residues to dots so only the changes stand out. Histone H4, one of the most conserved proteins known, is almost entirely dots relative to human — only the most distant lineages differ.',
  },
  {
    src: 'processing-conservation.png',
    title: 'Post-translational processing',
    body: 'Insulin relative to human: the mature B and A chains stay conserved (dots) while the cleaved-out C-peptide drifts (letters) — the same dot-diffing reading out where a protein is under selection.',
  },
  {
    src: 'gene-duplication.png',
    title: 'Gene duplication',
    body: 'The globin family groups by globin type across species rather than by species — alpha beside alpha, beta beside beta — the signature of ancient gene duplication read off the tree.',
  },
  {
    src: 'tree-of-life.png',
    title: 'Tree of life',
    body: 'Elongation factor EF-1α/EF-Tu across bacteria, archaea, and eukaryotes — the label prefixes make the three domains of life read straight off a single inferred tree.',
  },
  {
    src: 'rna-secondary-structure.png',
    title: 'RNA secondary structure',
    body: 'A tRNA alignment (Rfam RF00005): the Stockholm SS_cons cloverleaf renders as a dedicated secondary-structure track above the columns, with the acceptor stem and D-/anticodon-/T-arms colored by base-pairing.',
  },
  {
    src: 'f12-exon-architecture.png',
    title: 'Gene structure overlay (DNA)',
    body: 'Coagulation factor XII coding alignment with its 14 exons overlaid — each exon the same color across species, through the same overlay path as InterProScan domains (built by react-msaview-cli genestructure). The whole gene’s exon architecture reads straight down the alignment.',
  },
  {
    src: 'f12-frameshift.png',
    title: 'Pseudogenization (base resolution)',
    body: 'Zoomed to single nucleotides: F12 is intact in land mammals and the manatee, but a single-base deletion shared by exactly the four cetaceans — beside premature stops elsewhere — disables it. Gene loss visible at the base level, which a protein alignment cannot show.',
  },
  {
    src: 'gene-arrow-map.png',
    title: 'Gene-arrow map',
    body: 'A gggenes-style gene cluster across genomes, each gene a strand-directed arrow anchored to alignment columns: one gene is inverted (the arrow flips) and one deleted (its columns gap out), yet every gene stays column-aligned.',
  },
  {
    src: 'large-tree.png',
    title: 'Scale',
    body: 'A real ~60-sequence lysine-riboswitch family and its full inferred tree, rendered through the tiled canvas system that keeps large alignments responsive.',
  },
]

