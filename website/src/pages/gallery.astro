%3A%5B258%5D%2C%22msaFileLocation%22%3A%7B%22uri%22%3A%22https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Ftp53-p53-orthologs.fa%22%7D%2C%22treeFileLocation%22%3A%7B%22uri%22%3A%22https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Ftp53-p53.nh%22%7D%2C%22colorSchemeName%22%3A%22clustalx_protein_dynamic%22%2C%22labelsAlignRight%22%3Atrue%2C%22treeAreaWidth%22%3A200%7D%5D%7D'

// F12 in genomic coordinates: a plain genome view (no connected MSA) of the F12
// locus with the canonical transcript and the Multiz 470-way mammal MAF track —
// the genomic complement to the two F12 gene-loss figures above. Captured by
// scripts/screenshots/f12-genome-figure.mjs.
const f12Genome =
  'https://jbrowse.org/code/jb2/webgl-poc/?config=https%3A%2F%2Fgmod.org%2FJBrowseMSA%2Fdemo%2Fdata%2Fjbrowse-msa-combined-config.json&session=spec-%7B%22views%22%3A%5B%7B%22type%22%3A%22LinearGenomeView%22%2C%22id%22%3A%22lgv-f12%22%2C%22assembly%22%3A%22hg38%22%2C%22loc%22%3A%22chr5%3A177%2C401%2C800-177%2C409%2C900%22%2C%22colorByCDS%22%3Atrue%2C%22tracks%22%3A%5B%22hg38-ncbiRefSeqSelect%22%2C%22hg38-multiz470way%22%5D%7D%5D%7D'
---

<Base
  title="Gallery — JBrowseMSA"
  description="A gallery of react-msaview: alignments that tell a biological story, and connected JBrowse sessions linking genome, alignment, and 3D structure."
  wide
>
  <article class="prose">
    <h1>Gallery</h1>
    <p>
      Alignments and trees where the biology reads straight off the picture.
      Each is built reproducibly from public data by the scripts in the repo.
      Build your own from any gene on the{' '}
      <a href={`${base}/gene-explorer`}>JBrowse integration</a> page.
    </p>

    <div class="gallery">
      {
        figures.map(f => (
          <figure>
            <img src={`${base}/media/${f.src}`} alt={f.body} loading="lazy" />
            <figcaption>
              <strong>{f.title}</strong> — {f.body}
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p>
      The two F12 figures above are the curated coding alignment. The same gene
      in <em>genomic</em> coordinates — introns and all, with the raw Multiz 470-way
      mammal MAF track — is a separate genome-browser view rather than a duplicate
      alignment crammed into one session:
    </p>

    <figure>
      <a href={f12Genome} target="_blank" rel="noopener">
        <img
          src={`${base}/media/genome-browser-f12.png`}
          alt="JBrowse: the F12 locus on hg38 with the canonical RefSeq transcript colored by CDS frame, over the Multiz 470-way mammal MAF track showing the comparative alignment across mammals including dolphin and blue whale"
        />
      </a>
      <figcaption>
        The F12 locus (chr5, 14 exons) with the canonical RefSeq transcript over
        the Multiz 470-way mammal MAF track — two cetaceans (dolphin, blue
        whale) among the aligned mammals. The genomic context for the gene-loss
        alignment above.{' '}
        <a href={f12Genome} target="_blank" rel="noopener">Open in JBrowse ↗</a>
      </figcaption>
    </figure>

    <h2 id="combined">Genome + MSA in one view</h2>
    <p>
      The same gene as a <em>combined</em> JBrowse view: a genome browser with the
      gene annotation track on top, and the react-msaview MSA — DNA alignment,
      species tree, and the 14-exon model projected across every species — below.
      One JBrowse session, built by{' '}
      <code>scripts/screenshots/f12-combined-figure.mjs</code>. This is the viewer
      an MSA <em>editor</em> would build on: the exon model is already registered
      to the alignment columns and lifted onto each species.
    </p>

    <JBrowseFigure
      src="f12-combined-overview.png"
      href={f12CombinedOverviewUrl}
      alt="JBrowse combined view: the F12 locus with the RefSeq gene annotation track over a react-msaview panel showing the cetacean DNA coding alignment, the species tree, and the 14-exon model projected across every species as colored bands"
      body="The F12 locus (RefSeq annotation track, top) beside the cetacean DNA coding alignment with its species tree and 14-exon model (bottom) — each exon the same color across species, so the gene's exon architecture reads straight down the alignment, with per-row notches where indels shift a boundary."
    />

    <JBrowseFigure
      src="f12-combined-closeup.png"
      href={f12CombinedCloseupUrl}
      alt="The combined view zoomed to base resolution at exon 3: the four cetaceans show a gap where every other mammal has a C — the shared single-base frameshift — beside the exon-3/exon-4 boundary, with the species tree"
      body="The same combined view at base resolution over exon 3: the four cetaceans (beluga, porpoise, dolphin, minke whale) carry a single-base deletion — a gap where every other mammal has a C — that disables the gene, shown at the nucleotide level beside the exon-3/exon-4 boundary."
    />

    <h2 id="connected">Connected JBrowse sessions</h2>
    <p>
      react-msaview also runs as a{' '}
      <a href="https://github.com/GMOD/jbrowse-plugin-msaview"
        >JBrowse 2 plugin</a
      >: the alignment and tree open <em>inside</em> JBrowse, connected to a genome
      view and — with{' '}
      <a href="https://github.com/GMOD/jbrowse-plugin-protein3d">protein3d</a> — the
      AlphaFold structure. Each link below is one declarative URL.
    </p>

    <figure>
      <a href={tp53Protein3d} target="_blank" rel="noopener">
        <img
          src={`${base}/media/genome-browser-tp53-protein3d.png`}
          alt="JBrowse: the TP53 gene with ClinVar, the p53 ortholog alignment, and the AlphaFold structure, all connected, with the nuclear export signal motif lit across genome, alignment, and 3D structure"
        />
      </a>
      <figcaption>
        Genome ↔ alignment ↔ 3D structure: the TP53 gene (RefSeq + ClinVar), the
        p53 ortholog alignment, and the AlphaFold structure as one connected
        session, opened with the nuclear export signal motif (residues 339–350)
        lit across all three.{' '}
        <a href={tp53Protein3d} target="_blank" rel="noopener"
          >Open in JBrowse ↗</a
        >
      </figcaption>
    </figure>

    <figure>
      <a href={`${base}/gene-explorer`}>
        <img
          src={`${base}/media/gene-explorer-protein3d-linkage.png`}
          alt="The gene explorer's connected session for TP53: a span of residues selected on the AlphaFold structure lights the same codons on the collapsed-intron genome view and the 100-way alignment"
        />
      </a>
      <figcaption>
        Built on the fly by the{' '}
        <a href={`${base}/gene-explorer`}>gene explorer</a> for any human gene: selecting
        a span of residues on the AlphaFold structure lights the exact same codons
        on the collapsed-intron genome view (the yellow band) and the 100-way alignment
        — structure ↔ genome ↔ alignment, codon-precise.
      </figcaption>
    </figure>

    <p>The same connected pattern without the structure view:</p>
    <ul>
      <li>
        <a href={proteinLinked} target="_blank" rel="noopener">SRC ↗</a> — the Src-family
        kinase alignment beside the SRC gene.
      </li>
      <li>
        <a href={brafV600} target="_blank" rel="noopener">BRAF V600E ↗</a> — the RAF
        family on the invariant V600 codon, with a ClinVar pathogenic-variant track.
      </li>
      <li>
        <a href={tp53R248} target="_blank" rel="noopener">TP53 R248 ↗</a> — p53 across
        vertebrates on the R248 hotspot, with ClinVar.
      </li>
    </ul>
  </article>
</Base>
